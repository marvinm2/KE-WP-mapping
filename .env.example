# KE-WP Mapping Application Configuration
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000
HOST=127.0.0.1

# GitHub OAuth Configuration
# Get these from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Database Configuration
DATABASE_PATH=ke_wp_mapping.db

# Admin Users (comma-separated, supports provider prefix e.g. github:alice,orcid:0000-...)
ADMIN_USERS=yourusername,otheradmin

# Optional: Rate Limiting
RATELIMIT_STORAGE_URL=memory://

# Zenodo Dataset Publication (Phase 5)
# Get token from: Zenodo Dashboard -> Settings -> Applications -> Personal access tokens
# Required scope: deposit:write
ZENODO_API_TOKEN=your-zenodo-api-token-here

# Optional: Additional OAuth Providers (activate by setting both ID and SECRET)
# ORCID: Register at https://orcid.org/developer-tools
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# LS Login: Register at https://login.elixir-czech.org
LS_CLIENT_ID=
LS_CLIENT_SECRET=

# SURFconext: Register at https://dashboard.surfconext.nl
SURF_CLIENT_ID=
SURF_CLIENT_SECRET=
